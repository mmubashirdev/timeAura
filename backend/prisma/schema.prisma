generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
}

model Product {
  id             Int              @id @default(autoincrement())
  name           String
  slug           String           @unique
  description    String?
  categoryId     Int
  basePrice      Int
  compareAtPrice Int?
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  brand          String
  color          String
  colorHex       String
  image          String
  isNew          Boolean          @default(false)
  isSale         Boolean          @default(false)
  material       String
  rating         Float            @default(0)
  reviewCount    Int              @default(0)
  cartItems      CartItem[]
  category       Category         @relation(fields: [categoryId], references: [id])
  images         ProductImage[]
  variants       ProductVariant[]

  @@index([categoryId])
  @@index([brand])
  @@index([material])
  @@index([color])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String
  altText   String?
  position  Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id            Int         @id @default(autoincrement())
  productId     Int
  sku           String      @unique
  optionName    String
  optionValue   String
  priceOverride Int?
  stock         Int         @default(0)
  orderItems    OrderItem[]
  product       Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model User {
  id                  Int        @id @default(autoincrement())
  name                String
  email               String     @unique
  passwordHash        String?
  role                UserRole   @default(STAFF)
  isEmailVerified     Boolean    @default(false)
  refreshTokenVersion Int        @default(0)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  googleId            String?    @unique
  cart                Cart?
  otpTokens           OtpToken[]
}

model OtpToken {
  id         Int       @id @default(autoincrement())
  userId     Int
  type       OtpType
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique
  email     String?
  address   String
  city      String
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id             Int           @id @default(autoincrement())
  customerId     Int
  status         OrderStatus   @default(PENDING)
  paymentMethod  PaymentMethod
  totalAmount    Int
  trackingNumber String?
  courier        String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  customer       Customer      @relation(fields: [customerId], references: [id])
  items          OrderItem[]

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id        Int            @id @default(autoincrement())
  orderId   Int
  variantId Int
  quantity  Int
  unitPrice Int
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}

model Cart {
  id         Int        @id @default(autoincrement())
  userId     Int?       @unique
  guestToken String?    @unique
  couponCode String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  items      CartItem[]
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  productId Int
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([cartId, productId])
}

model Coupon {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  type      CouponType
  value     Int
  label     String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
}

enum PaymentMethod {
  COD
  JAZZCASH
  EASYPAISA
  CARD
}

enum UserRole {
  ADMIN
  STAFF
}

enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

enum CouponType {
  PERCENT
  FLAT
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}
