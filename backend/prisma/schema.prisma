// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}



enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  RETURNED
}

enum PaymentMethod {
  COD
  JAZZCASH
  EASYPAISA
  CARD
}

model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique   // "Watches", "Wallets", "Perfumes"
  slug      String    @unique
  products  Product[]
  createdAt DateTime  @default(now())
}

model Product {
  id              Int              @id @default(autoincrement())
  name            String
  slug            String           @unique
  description     String?
  categoryId      Int
  category        Category         @relation(fields: [categoryId], references: [id])
  brand           String
  material        String
  color           String
  colorHex        String
  basePrice       Int
  compareAtPrice  Int?
  rating          Float            @default(0)
  reviewCount     Int              @default(0)
  isNew           Boolean          @default(false)
  isSale          Boolean          @default(false)
  image           String           // primary image path/URL — kept alongside ProductImage[] for future gallery support
  images          ProductImage[]
  variants        ProductVariant[]
  cartItems       CartItem[]
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([categoryId])
  @@index([brand])
  @@index([material])
  @@index([color])
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  position  Int      @default(0)
}

// Generic variant model — a watch might have "Strap Color: Rose Gold",
// a perfume might have "Size: 50ml". Don't hardcode columns per product type.
model ProductVariant {
  id          Int       @id @default(autoincrement())
  productId   Int
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku         String    @unique
  optionName  String    // e.g. "Color", "Size"
  optionValue String    // e.g. "Rose Gold", "50ml"
  priceOverride Int?    // null = use product.basePrice
  stock       Int       @default(0)
  orderItems  OrderItem[]

  @@index([productId])
}

enum UserRole {
  ADMIN
  STAFF
}

// prisma/schema.prisma — update the User model
model User {
  id                  Int      @id @default(autoincrement())
  name                String
  email               String   @unique
  passwordHash        String?  // nullable — Google-only accounts have no local password
  googleId            String?  @unique
  role                UserRole @default(STAFF)
  isEmailVerified     Boolean  @default(false)
  refreshTokenVersion Int      @default(0)
  otpTokens           OtpToken[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  cart Cart?
}
enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

model OtpToken {
  id         Int       @id @default(autoincrement())
  userId     Int
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       OtpType
  codeHash   String
  expiresAt  DateTime
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, type])
}

model Customer {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String   @unique   // Pakistani market: phone is the real identity, not email
  email     String?
  address   String
  city      String
  orders    Order[]
  createdAt DateTime @default(now())
}

model Order {
  id            Int           @id @default(autoincrement())
  customerId    Int
  customer      Customer      @relation(fields: [customerId], references: [id])
  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod
  totalAmount   Int           // snapshot total, in PKR — never recompute from live prices later
  trackingNumber String?
  courier       String?
  items         OrderItem[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([customerId])
  @@index([status])
}

model OrderItem {
  id          Int             @id @default(autoincrement())
  orderId     Int
  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variantId   Int
  variant     ProductVariant  @relation(fields: [variantId], references: [id])
  quantity    Int
  unitPrice   Int             // price AT TIME OF ORDER, not a live reference
}

model Cart {
  id         Int        @id @default(autoincrement())
  userId     Int?       @unique
  user       User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestToken String?    @unique // opaque id stored in an httpOnly cookie for anonymous carts
  couponCode String?
  items      CartItem[]
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

model CartItem {
  id        Int      @id @default(autoincrement())
  cartId    Int
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([cartId, productId])
}

enum CouponType {
  PERCENT
  FLAT
}

model Coupon {
  id        Int        @id @default(autoincrement())
  code      String     @unique
  type      CouponType
  value     Int
  label     String
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
}
