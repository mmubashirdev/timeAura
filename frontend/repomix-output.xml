@import "tailwindcss";
/* @import "tw-animate-css"; */

@custom-variant dark (&:is(.dark *));

:root {
  --radius: 1rem; /* 16px per design system */

  --background: #FAFAFA;
  --foreground: #171717;

  --card: #ffffff;
  --card-foreground: #171717;

  --popover: #ffffff;
  --popover-foreground: #171717;

  /* Primary = Maroon */
  --primary: #800020;
  --primary-foreground: #ffffff;

  --secondary: #f5f5f5;
  --secondary-foreground: #171717;

  --muted: #f5f5f5;
  --muted-foreground: #737373;

  /* Accent = Gold */
  --accent: #C9A14A;
  --accent-foreground: #171717;

  --destructive: #dc2626;
  --destructive-foreground: #ffffff;

  --border: #e5e5e5;
  --input: #e5e5e5;
  --ring: #800020;
}

.dark {
  --background: #111111;
  --foreground: #FAFAFA;
  --card: #1a0a10;
  --card-foreground: #FAFAFA;
  --primary: #C9A14A;
  --primary-foreground: #111111;
  --border: #2a1a20;
  --input: #2a1a20;
  --ring: #C9A14A;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-card: var(--card);
  --color-card-foreground: var(--card-foreground);
  --color-popover: var(--popover);
  --color-popover-foreground: var(--popover-foreground);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-secondary: var(--secondary);
  --color-secondary-foreground: var(--secondary-foreground);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --color-destructive: var(--destructive);
  --color-destructive-foreground: var(--destructive-foreground);
  --color-border: var(--border);
  --color-input: var(--input);
  --color-ring: var(--ring);
  --radius-sm: calc(var(--radius) - 4px);
  --radius-md: calc(var(--radius) - 2px);
  --radius-lg: var(--radius);
  --radius-xl: calc(var(--radius) + 4px);

  --font-serif: var(--font-playfair);
  --font-sans: var(--font-inter);
}

* {
  box-sizing: border-box;
}

html, body {
  margin: 0;
  padding: 0;
  height: 100%;
  /* Allow layout containers to manage scrolling; prevents stray page scrollbars */
  overflow: hidden;
  font-family: var(--font-inter), system-ui, sans-serif;
  background: var(--background);
  color: var(--foreground);
  -webkit-font-smoothing: antialiased;
}

/* Ensure auth panels don't force body scrolling */
#__next {
  height: 100%;
}


/* Neutral scrollbar for internal scroll containers */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: #d4d4d4; border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #a3a3a3; }

.font-serif {
  font-family: var(--font-playfair), Georgia, serif;
}

/* Elevate hero title */
.elevate-title {
  background: linear-gradient(180deg, #ffffff 0%, #f4e4d4 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.script-text {
  font-family: 'Brush Script MT', 'Segoe Script', cursive;
  color: #d97706;
}

::-webkit-scrollbar { width: 8px; }
::-webkit-scrollbar-track { background: #1a0a10; }
::-webkit-scrollbar-thumb { background: #800020; border-radius: 4px; }

/* Legal document typography */
.legal-prose p {
